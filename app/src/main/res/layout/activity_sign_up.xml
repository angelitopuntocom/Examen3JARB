<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F0FA"
    tools:context=".SignUpActivity">

    <EditText
        android:id="@+id/etRegistroUsuario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_registro_usuario"
        android:inputType="text"
        android:autofillHints="username"
        android:minHeight="48dp"
        android:textColorHint="#757575"
        android:background="@android:color/transparent"
        android:layout_marginTop="80dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etRegistroContrasena"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_registro_contrasena"
        android:inputType="textPassword"
        android:autofillHints="password"
        android:minHeight="48dp"
        android:textColorHint="#757575"
        android:background="@android:color/transparent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/etRegistroUsuario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnConfirmarRegistro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_registrarse"
        android:backgroundTint="#7B5EA7"
        android:textColor="#FFFFFF"
        android:layout_marginTop="32dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/etRegistroContrasena"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>